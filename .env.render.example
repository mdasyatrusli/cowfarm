# =====================================================================
# Contoh environment variables untuk deploy di Render (Web Service)
# Copy isi ini ke "Environment" pada dashboard Render, atau gunakan
# sebagai blueprint. Render otomatis menyediakan DATABASE_URL untuk
# PostgreSQL managed instance — Laravel 12 bisa membacanya langsung.
# =====================================================================

APP_NAME=CowFarm
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://cowfarm.onrender.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

# --- Database: PostgreSQL (Render managed) ---
# Render menyediakan DATABASE_URL otomatis. Baris di bawah ini
# memastikan Laravel membacanya sebagai koneksi pgsql.
DB_CONNECTION=pgsql
DATABASE_URL=${DATABASE_URL}

# Fallback manual (isi jika tidak pakai DATABASE_URL Render):
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

# --- Session / Cache / Queue (pakai database bawaan) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Filesystem ---
FILESYSTEM_DISK=local

# --- Mail (log di production, ganti bila perlu SMTP) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@cowfarm.onrender.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"